{
  "name": "@inscada/web-components",
  "version": "2.0.0-alpha.2",
  "description": "inSCADA Web Components (JDK21) — live values, faceplates, REST fetch. <ins-faceplate> v3 uses the domain FaceplateApi (getFaceplateByName/Svg/Elements/Placeholders) — requires backend build ≥ 20260706-8.",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src/",
    "dist/"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --minify --format=iife --global-name=InsComponents --outfile=dist/ins-components.min.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "inscada",
    "scada",
    "web-components",
    "live-value",
    "faceplate",
    "industrial"
  ],
  "license": "MIT",
  "author": "INS Yazilim Sanayi ve Ticaret A.S.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inscada-app/inscada-web-components.git"
  },
  "bugs": {
    "url": "https://github.com/inscada-app/inscada-web-components/issues"
  },
  "homepage": "https://github.com/inscada-app/inscada-web-components#readme"
}
