{
  "name": "@inscada/web-components",
  "version": "1.0.0-beta.1",
  "description": "inSCADA Web Components (JDK21) — Transport-abstracted live values, faceplates, REST fetch. Auto-detects iframe (InscadaApi proxy) vs same-origin standalone.",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src/",
    "dist/"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --minify --format=iife --global-name=InsComponents --outfile=dist/ins-components.min.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "inscada",
    "scada",
    "web-components",
    "live-value",
    "faceplate",
    "industrial"
  ],
  "license": "MIT"
}
