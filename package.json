  "repository": {
    "type": "git",
    "url": "git+https://github.com/inscada-app/inscada-web-components.git"
  },
  "bugs": {
    "url": "https://github.com/inscada-app/inscada-web-components/issues"
  },
  "homepage": "https://github.com/inscada-app/inscada-web-components#readme"
}
